rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: public read, authenticated write only
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: public create (anyone can submit a quote request),
    // authenticated read/update/delete (admin only)
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['items', 'total', 'createdAt']);
      allow read, update, delete: if request.auth != null;
    }

    // Analytics: public write for client-side event tracking,
    // authenticated read (admin reports panel)
    match /analytics/{document=**} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
